{
  "name": "@paragraf/font-engine",
  "version": "0.3.0",
  "description": "Font metrics abstraction, fontkit adapter, and measurer factory for the paragraf typesetter.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kadetr/paragraf.git",
    "directory": "1b-font-engine"
  },
  "homepage": "https://github.com/kadetr/paragraf/tree/main/1b-font-engine#readme",
  "keywords": [
    "typography",
    "typesetting",
    "font",
    "fontkit",
    "paragraf"
  ],
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../scripts/publishconfig-swap.mjs apply",
    "postpack": "node ../scripts/publishconfig-swap.mjs restore"
  },
  "dependencies": {
    "@paragraf/types": "^0.3.0",
    "fontkit": "^2.0.4"
  },
  "devDependencies": {
    "@types/fontkit": "^2.0.9",
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
