{
  "name": "@paragraf/linebreak",
  "version": "0.6.0",
  "description": "Knuth-Plass line-breaking algorithm + hyphenation. Browser-safe, zero font dependencies.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kadetr/paragraf.git",
    "directory": "1a-linebreak"
  },
  "homepage": "https://github.com/kadetr/paragraf/tree/main/1a-linebreak#readme",
  "keywords": [
    "typography",
    "typesetting",
    "knuth-plass",
    "line-breaking",
    "hyphenation",
    "paragraf"
  ],
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../scripts/publishconfig-swap.mjs apply",
    "postpack": "node ../scripts/publishconfig-swap.mjs restore"
  },
  "dependencies": {
    "@paragraf/types": "^0.6.0",
    "hyphen": "^1.14.1"
  },
  "devDependencies": {
    "@types/fontkit": "^2.0.9",
    "@types/node": "^22.19.15",
    "fontkit": "^2.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
