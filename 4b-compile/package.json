{
  "name": "@paragraf/compile",
  "version": "0.5.0",
  "description": "Document compile pipeline for the paragraf typesetter. Merges template, data, fonts, layout, and styles into a rendered PDF, SVG, or document model.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kadetr/paragraf.git",
    "directory": "4b-compile"
  },
  "homepage": "https://github.com/kadetr/paragraf/tree/main/4b-compile#readme",
  "keywords": [
    "typography",
    "typesetting",
    "compile",
    "pdf",
    "paragraf"
  ],
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../scripts/publishconfig-swap.mjs apply",
    "postpack": "node ../scripts/publishconfig-swap.mjs restore"
  },
  "dependencies": {
    "@paragraf/types": "^0.5.0",
    "@paragraf/layout": "^0.5.0",
    "@paragraf/style": "^0.5.0",
    "@paragraf/template": "^0.5.0",
    "@paragraf/font-engine": "^0.5.0",
    "@paragraf/linebreak": "^0.5.0",
    "@paragraf/typography": "^0.3.0",
    "@paragraf/render-core": "^0.3.0",
    "@paragraf/render-pdf": "^0.3.0"
  },
  "optionalDependencies": {
    "@paragraf/shaping-wasm": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
