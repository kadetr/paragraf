{
  "name": "@paragraf/color-wasm",
  "version": "0.6.0",
  "description": "Rust/WASM ICC color transform backend for @paragraf/color.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kadetr/paragraf.git",
    "directory": "2c-color-wasm"
  },
  "homepage": "https://github.com/kadetr/paragraf/tree/main/2c-color-wasm#readme",
  "keywords": [
    "typography",
    "typesetting",
    "wasm",
    "color",
    "icc",
    "paragraf"
  ],
  "type": "module",
  "files": [
    "dist/",
    "wasm/pkg/",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../scripts/publishconfig-swap.mjs apply",
    "postpack": "node ../scripts/publishconfig-swap.mjs restore",
    "build:wasm": "cd wasm && wasm-pack build --target nodejs --out-dir pkg"
  },
  "dependencies": {
    "@paragraf/color": "^0.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
