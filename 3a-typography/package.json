{
  "name": "@paragraf/typography",
  "version": "0.6.0",
  "description": "Paragraph compositor, optical margin alignment, and document model for the paragraf typesetter.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kadetr/paragraf.git",
    "directory": "3a-typography"
  },
  "homepage": "https://github.com/kadetr/paragraf/tree/main/3a-typography#readme",
  "keywords": [
    "typography",
    "typesetting",
    "knuth-plass",
    "line-breaking",
    "paragraf"
  ],
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "benchmark:cache": "tsx scripts/benchmark-cache.ts",
    "prepack": "node ../scripts/publishconfig-swap.mjs apply",
    "postpack": "node ../scripts/publishconfig-swap.mjs restore"
  },
  "dependencies": {
    "@paragraf/types": "^0.6.0",
    "@paragraf/linebreak": "^0.6.0",
    "@paragraf/font-engine": "^0.6.0",
    "@paragraf/shaping-wasm": "^0.6.0",
    "@paragraf/render-core": "^0.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
