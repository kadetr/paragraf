{
  "name": "@paragraf/layout",
  "version": "0.5.0",
  "description": "Page geometry, unit converters, and named page sizes for the paragraf typesetter.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kadetr/paragraf.git",
    "directory": "1c-layout"
  },
  "homepage": "https://github.com/kadetr/paragraf/tree/main/1c-layout#readme",
  "keywords": [
    "typography",
    "typesetting",
    "layout",
    "page",
    "geometry",
    "paragraf"
  ],
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../scripts/publishconfig-swap.mjs apply",
    "postpack": "node ../scripts/publishconfig-swap.mjs restore"
  },
  "dependencies": {
    "@paragraf/types": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
